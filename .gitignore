.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
# Editor/IDE files
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# PlatformIO (firmware build artifacts)
# ============================================================
.pio/
.pioenvs/
.piolibdeps/
.clang_complete
.gcc-flags.json
firmware/.pio/

# ============================================================
# C/C++ build artifacts
# ============================================================
*.o
*.obj
*.exe
*.out
*.app
*.elf
*.bin
*.hex
*.map
build/
dist/

# ============================================================
# Rust (host daemon build artifacts)
# ============================================================
target/
**/*.rs.bk
Cargo.lock

# ============================================================
# Python (build/release scripts, if any)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env

# ============================================================
# Secrets - NEVER commit these
# ============================================================
*.key
*.pem
secrets/
config.local.*
.env.local
